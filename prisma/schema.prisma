generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  WAITER
  KASIR
  OWNER
  DAPUR
}

enum OrderType {
  DINE_IN
  TAKEAWAY
}

enum OrderStatus {
  PENDING_CONFIRMATION
  OPEN
  PARTIALLY_PAID
  PAID
  CANCELLED
}

enum PaymentMethod {
  CASH
  QRIS
}

enum OrderSource {
  WAITER
  ONLINE
}

enum ModRequestType {
  EDIT_ITEM
  REMOVE_ITEM
  CANCEL_ORDER
}

enum ModRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum StockChangeType {
  SOLD
  RESTOCK
  DAILY_RESET
}

model User {
  id                    String                     @id @default(cuid())
  name                  String
  username              String                     @unique
  pin                   String
  role                  Role
  isActive              Boolean                    @default(true)
  createdAt             DateTime                   @default(now())
  orders                Order[]
  expenses              Expense[]
  modRequestsMade       OrderModificationRequest[]  @relation("requestedBy")
  modRequestsReviewed   OrderModificationRequest[]  @relation("reviewedBy")
}

model Category {
  id        String     @id @default(cuid())
  name      String     @unique
  sortOrder Int        @default(0)
  menuItems MenuItem[]
}

model MenuItem {
  id                   String               @id @default(cuid())
  name                 String
  categoryId           String
  category             Category             @relation(fields: [categoryId], references: [id])
  price                Int
  initialStock         Int
  currentStock         Int
  minThreshold         Float                @default(0.25)
  imageUrl             String?
  isActive             Boolean              @default(true)
  createdAt            DateTime             @default(now())
  orderItems           OrderItem[]
  stockLogs            StockLog[]
  restockNotifications RestockNotification[]
}

model Order {
  id            String      @id @default(cuid())
  orderNumber   String      @unique
  type          OrderType
  status        OrderStatus @default(OPEN)
  source        OrderSource @default(WAITER)
  tableNumber   Int?
  customerNote  String?
  rejectReason  String?
  splitPlan     String?     @db.Text
  createdById   String?
  createdBy     User?       @relation(fields: [createdById], references: [id])
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  items                 OrderItem[]
  transactions          Transaction[]
  modificationRequests  OrderModificationRequest[]
}

model OrderItem {
  id           String   @id @default(cuid())
  orderId      String
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId   String
  menuItem     MenuItem @relation(fields: [menuItemId], references: [id])
  quantity     Int
  priceAtOrder Int
  createdAt    DateTime @default(now())
}

model Transaction {
  id            String        @id @default(cuid())
  orderId       String
  order         Order         @relation(fields: [orderId], references: [id])
  totalAmount   Int
  paymentMethod PaymentMethod
  cashReceived  Int?
  changeAmount  Int?
  splitGroup    String?
  splitLabel    String?
  isVoid        Boolean       @default(false)
  voidReason    String?
  paidAt        DateTime      @default(now())
}

model Expense {
  id           String   @id @default(cuid())
  date         DateTime
  description  String
  amount       Int
  recordedById String
  recordedBy   User     @relation(fields: [recordedById], references: [id])
  createdAt    DateTime @default(now())
}

model StockLog {
  id         String          @id @default(cuid())
  menuItemId String
  menuItem   MenuItem        @relation(fields: [menuItemId], references: [id])
  changeType StockChangeType
  quantity   Int
  note       String?
  createdAt  DateTime        @default(now())
}

model RestockNotification {
  id         String    @id @default(cuid())
  menuItemId String
  menuItem   MenuItem  @relation(fields: [menuItemId], references: [id])
  isResolved Boolean   @default(false)
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?
}

model OrderModificationRequest {
  id            String           @id @default(cuid())
  orderId       String
  order         Order            @relation(fields: [orderId], references: [id])
  requestedById String
  requestedBy   User             @relation("requestedBy", fields: [requestedById], references: [id])
  type          ModRequestType
  details       String           @db.Text
  reason        String
  status        ModRequestStatus @default(PENDING)
  reviewedById  String?
  reviewedBy    User?            @relation("reviewedBy", fields: [reviewedById], references: [id])
  reviewedAt    DateTime?
  reviewNote    String?
  createdAt     DateTime         @default(now())
}
